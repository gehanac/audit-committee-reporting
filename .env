# ── .env.example — AI Service Environment Variables ─────────────────────────
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to GitHub. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API Key (get yours free at https://console.groq.com)
GROQ_API_KEY=groq_api_key_here

# Redis connection (matches docker-compose service name "redis")
REDIS_HOST=redis
REDIS_PORT=6379

# ChromaDB persistent storage path (inside Docker container)
CHROMA_PATH=./chroma_data

# Flask environment
FLASK_ENV=production
FLASK_DEBUG=0